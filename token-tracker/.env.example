# Required: tag all API calls from this project
PROJECT_NAME=your-project-name

# Required: Supabase credentials — use the service_role key (NOT the anon key).
# The service_role key bypasses RLS and allows INSERT.
# Find it in: Supabase dashboard → Settings → API → service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...your-service-role-key...
